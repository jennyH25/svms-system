{
  "name": "svms-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=20.19.0"
  },
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "dev:full": "concurrently \"npm run api:dev\" \"npm run dev\"",
    "build": "vite build",
    "railway:build": "vite build",
    "api:start": "node server/index.js",
    "api:dev": "nodemon server/index.js",
    "desktop:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:5173 && electron .\"",
    "desktop:full": "concurrently \"npm run api:dev\" \"npm run dev\" \"wait-on http://localhost:5173 && electron .\"",
    "desktop:start": "npm run build && electron .",
    "lint": "eslint .",
    "preview": "vite preview",
    "db:test": "node scripts/test-mysql.js"
  },
  "dependencies": {
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-slot": "^1.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^5.1.0",
    "gsap": "^3.14.2",
    "lucide-react": "^0.575.0",
    "motion": "^12.34.3",
    "mysql2": "^3.19.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.13.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
