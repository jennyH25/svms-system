{
  "name": "svms-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=20.19.0"
  },
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently \"npm run api:dev\" \"npm run dev:web\"",
    "dev:web": "vite",
    "dev:full": "npm run dev",
    "build": "vite build",
    "start": "node server/index.js",
    "api:start": "node server/index.js",
    "api:dev": "nodemon server/index.js",
    "desktop:dev": "concurrently \"npm run dev:web\" \"wait-on http://localhost:5173 && electron .\"",
    "desktop:full": "concurrently \"npm run api:dev\" \"npm run dev:web\" \"wait-on http://localhost:5173 && electron .\"",
    "desktop:start": "npm run build && electron .",
    "lint": "eslint .",
    "preview": "vite preview",
    "db:test": "node scripts/test-postgres.js",
    "db:setup-auth": "node scripts/setup-auth-db.js"
  },
  "dependencies": {
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-slot": "^1.2.4",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "exceljs": "^4.4.0",
    "express": "^5.1.0",
    "gsap": "^3.14.2",
    "jspdf": "^4.2.0",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^0.575.0",
    "motion": "^12.34.3",
    "multer": "^2.1.1",
    "nodemailer": "^7.0.13",
    "postgres": "^3.4.7",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.13.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/nodemailer": "^7.0.11",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/wait-on": "^5.3.4",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "electron": "^37.3.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "nodemon": "^3.1.10",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.4",
    "vite": "^7.3.1",
    "wait-on": "^8.0.5"
  }
}
